<div class="profile-header">
  <div class="profile-avatar">⚔️</div>
  <div>
    <div class="profile-name"><%= @user.email %></div>
    <div class="profile-title"><%= @user.current_title %></div>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-box">
    <div class="stat-val">Lv.<%= @user.level %></div>
    <div class="stat-label">レベル</div>
  </div>
  <div class="stat-box exp-box">
    <div class="stat-val"><%= @user.exp %></div>
    <div class="stat-label">累計 EXP</div>
  </div>
  <div class="stat-box">
    <div class="stat-val"><%= @user.gold %>G</div>
    <div class="stat-label">所持 Gold</div>
  </div>
  <div class="stat-box streak-box">
    <div class="stat-val"><%= @user.streak %>日</div>
    <div class="stat-label">連続プレイ</div>
  </div>
</div>

<% unless @user.level >= User::MAX_LEVEL %>
  <% exp_start = User.exp_required_for_level(@user.level) %>
  <% exp_end   = User.exp_required_for_level(@user.level + 1) %>
  <% exp_pct   = ((@user.exp - exp_start).to_f / [exp_end - exp_start, 1].max * 100).clamp(0, 100).round %>
  <div class="profile-exp-bar card">
    <p class="card-title">EXP 進捗</p>
    <div class="bar-bg">
      <div class="bar-fill" style="width:<%= exp_pct %>%"></div>
    </div>
    <p class="bar-label">次のレベルまで あと <%= @user.exp_to_next_level %> EXP</p>
  </div>
<% else %>
  <div class="card card-gold" style="text-align:center; padding:1.5rem;">
    <p style="font-size:1.2rem; font-weight:700; color:var(--gold);">🏆 最大レベル達成！伝説の賢者</p>
  </div>
<% end %>

<p class="text-muted" style="font-size:0.82rem; margin-bottom:1.25rem;">
  最終プレイ日: <%= @user.last_played_date&.strftime("%Y/%m/%d") || "まだプレイしていません" %>
</p>

<div class="card">
  <p class="card-title">最近の挑戦記録</p>
  <% if @recent_attempts.empty? %>
    <p class="text-muted" style="font-size:0.9rem;">まだクエストをクリアしていません。</p>
  <% else %>
    <table class="rpg-table">
      <thead>
        <tr>
          <th>日付</th>
          <th>ジャンル</th>
          <th>難易度</th>
          <th>結果</th>
          <th>EXP</th>
          <th>Gold</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_attempts.each do |attempt| %>
          <tr>
            <td><%= attempt.created_at.strftime("%m/%d") %></td>
            <td>
              <% case attempt.quest.daily_challenge.genre
                 when "calculation" then %>🧮
              <% when "memory"      then %>🧠
              <% when "word_puzzle" then %>📝
              <% end %>
            </td>
            <td>
              <span class="stars">
                <% case attempt.quest.difficulty
                   when "easy"   then %>★
                <% when "normal" then %>★★
                <% when "hard"   then %>★★★
                <% end %>
              </span>
            </td>
            <td>
              <% if attempt.correct %>
                <span class="correct-cell">正解</span>
              <% else %>
                <span class="incorrect-cell">不正解</span>
              <% end %>
            </td>
            <td style="color:var(--exp-color);">+<%= attempt.earned_exp %></td>
            <td style="color:var(--gold);">+<%= attempt.earned_gold %>G</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%= link_to "← 依頼板に戻る", root_path, class: "text-muted" %>
