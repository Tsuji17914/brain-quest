<div class="auth-wrap">
  <div class="auth-card">
    <p class="auth-title">⚔️ Brain Quest<br><span style="font-size:0.85rem; font-weight:400; color:var(--text-muted);">ログイン</span></p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-group">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-group" style="display:flex; align-items:center; gap:0.5rem;">
          <%= f.check_box :remember_me, style: "width:auto;" %>
          <%= f.label :remember_me, "ログイン状態を保持", style: "margin:0; font-size:0.85rem;" %>
        </div>
      <% end %>

      <div class="form-actions">
        <%= f.submit "ログイン", class: "btn btn-primary", style: "width:100%;" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
