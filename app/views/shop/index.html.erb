<div class="shop-header">
  <span class="shop-header-title">🏺 道具屋</span>
  <span class="shop-header-gold">💰 所持 Gold: <%= current_user.gold %>G</span>
</div>

<div class="shop-shelf">
  <div class="shop-grid">
    <% @items.each do |item| %>
      <div class="shop-card">
        <div class="item-name">
          <% case item.effect
             when "holy_water" then %>🌊 <%= item.name %>
          <% when "sage_stone" then %>💎 <%= item.name %>
          <% when "hint_book"  then %>📖 <%= item.name %>
          <% end %>
        </div>
        <p class="item-desc"><%= item.description %></p>
        <p class="item-owned">所持: <%= (@user_items[item.effect] || []).count %>個</p>
        <div class="item-footer">
          <span class="item-price">💰 <%= item.price %>G</span>
          <%= form_with url: shop_purchases_path(item), method: :post do |f| %>
            <%= f.submit "購入する", class: "paper-btn",
                  style: "padding:0.3rem 0.8rem; font-size:0.8rem; cursor:#{current_user.gold < item.price ? 'not-allowed' : 'pointer'}; opacity:#{current_user.gold < item.price ? '0.45' : '1'};",
                  disabled: current_user.gold < item.price %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if @inventory.any? %>
  <div class="inventory-section">
    <div class="inventory-title">🎒 所持品</div>
    <div class="inventory-grid">
      <% @inventory.each do |effect, info| %>
        <% item = @items.find { |i| i.effect == effect } %>
        <% next unless item %>
        <div class="inventory-card">
          <div class="inventory-item-name">
            <% case effect
               when "holy_water" then %>🌊 <%= item.name %>
            <% when "sage_stone" then %>💎 <%= item.name %>
            <% when "hint_book"  then %>📖 <%= item.name %>
            <% end %>
          </div>
          <p class="inventory-count">所持 <%= info[:total] %>個 / 装備中 <%= info[:activated] %>個</p>
          <p class="inventory-effect-desc">
            <% case effect
               when "sage_stone" then %>装備中は初回クリアのEXPが2倍
            <% when "holy_water" then %>装備中はストリーク切れを1回防ぐ
            <% when "hint_book"  then %>装備中はクエスト中にヒントを見られる
            <% end %>
          </p>
          <div class="inventory-actions">
            <% if info[:activated] > 0 %>
              <span class="inventory-badge-active">装備中 ✓</span>
              <%= form_with url: deactivate_user_item_path, method: :post do |f| %>
                <%= f.hidden_field :effect, value: effect %>
                <%= f.submit "外す", class: "paper-btn inventory-btn-off" %>
              <% end %>
            <% end %>
            <% if info[:total] > info[:activated] %>
              <%= form_with url: activate_user_item_path, method: :post do |f| %>
                <%= f.hidden_field :effect, value: effect %>
                <%= f.submit "装備する", class: "paper-btn inventory-btn-on" %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="mt-3">
  <%= link_to "← 依頼板に戻る", root_path, class: "text-muted" %>
</div>
