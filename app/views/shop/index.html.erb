<div class="page-header">
  <h1>🏪 アイテムショップ</h1>
  <p class="page-subtitle">所持 Gold: <span class="text-gold"><%= current_user.gold %>G</span></p>
</div>

<div class="shop-grid">
  <% @items.each do |item| %>
    <div class="shop-card">
      <div class="item-name">
        <% case item.effect
           when "holy_water"  then %>🌊 <%= item.name %>
        <% when "sage_stone"  then %>💎 <%= item.name %>
        <% when "hint_book"   then %>📖 <%= item.name %>
        <% end %>
      </div>
      <p class="item-desc"><%= item.description %></p>
      <p class="item-owned">所持: <%= (@user_items[item.effect] || []).count %>個</p>
      <div class="item-footer">
        <span class="item-price">💰 <%= item.price %>G</span>
        <%= form_with url: shop_purchases_path(item), method: :post do |f| %>
          <%= f.submit "購入する", class: "btn btn-gold btn-sm",
                disabled: current_user.gold < item.price %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-3">
  <%= link_to "← 依頼板に戻る", root_path, class: "text-muted" %>
</div>
