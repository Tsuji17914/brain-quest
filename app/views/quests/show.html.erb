<h1>クエスト挑戦中</h1>

<p>ジャンル: <%= @quest.daily_challenge.genre %> |
難易度:
<% case @quest.difficulty
   when "easy"   then %>★ 易しい
<% when "normal" then %>★★ 普通
<% when "hard"   then %>★★★ 難しい
<% end %>
</p>

<p>報酬: EXP +<%= @quest.exp_reward %> / Gold +<%= @quest.gold_reward %>G</p>

<%= form_with url: quest_attempts_path(@quest), method: :post do |f| %>
  <% genre = @quest.daily_challenge.genre %>

  <% if genre == "memory" %>
    <p id="countdown" style="font-size:2rem;"></p>
    <p id="sequence-display" style="display:none;"><%= @quest.question_data["sequence"].join("  ") %></p>
    <p id="sequence-hidden" style="display:none;">数列を入力してください（붙여서もOK）</p>
    <%= f.text_field :answer, placeholder: "例: 3141 または 3 1 4 1", id: "memory-answer", style: "display:none;" %>
    <%= f.submit "回答する", id: "memory-submit", style: "display:none;" %>

  <% elsif genre == "word_puzzle" %>
    <h2><%= @quest.question_data["question"] %></h2>
    <% @quest.question_data["choices"].each do |choice| %>
      <div>
        <%= f.radio_button :answer, choice %>
        <%= f.label :answer, choice, value: choice %>
      </div>
    <% end %>
    <%= f.submit "回答する" %>

  <% else %>
    <%# calculation %>
    <h2><%= @quest.question_data["question"] %></h2>
    <%= f.number_field :answer, placeholder: "数字を入力" %>
    <%= f.submit "回答する" %>
  <% end %>
<% end %>

<%= link_to "依頼板に戻る", root_path %>

<script>
  (function() {
    var countdown = document.getElementById('countdown');
    if (!countdown) return;

    var count = 3;
    countdown.textContent = count;

    var timer = setInterval(function() {
      count -= 1;
      if (count > 0) {
        countdown.textContent = count;
      } else {
        clearInterval(timer);
        countdown.style.display = 'none';
        var display = document.getElementById('sequence-display');
        display.style.display = 'block';

        setTimeout(function() {
          display.style.display = 'none';
          document.getElementById('sequence-hidden').style.display = 'block';
          document.getElementById('memory-answer').style.display = 'inline';
          document.getElementById('memory-submit').style.display = 'inline';
        }, 1000);
      }
    }, 1000);
  })();
</script>
