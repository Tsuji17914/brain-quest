<div class="page-header">
  <div class="flex items-center gap-2 flex-wrap">
    <% case @quest.difficulty
       when "easy"   then %><span class="badge badge-easy">易しい</span>
    <% when "normal" then %><span class="badge badge-normal">普通</span>
    <% when "hard"   then %><span class="badge badge-hard">難しい</span>
    <% end %>
    <span class="genre-badge">
      <% case @quest.daily_challenge.genre
         when "calculation" then %>🧮 計算
      <% when "memory"      then %>🧠 記憶
      <% when "word_puzzle" then %>📝 言葉パズル
      <% end %>
    </span>
  </div>
  <div class="quest-rewards mt-1" style="font-size:0.9rem;">
    <% if @already_cleared %>
      <span class="text-muted">✓ クリア済み（報酬受取済み）</span>
    <% elsif @difficulty_rewarded_today %>
      <span class="text-muted">本日この難易度の報酬は受け取り済み</span>
    <% else %>
      <span class="exp-val">EXP +<%= @quest.exp_reward %></span>
      <span class="gold-val">💰 +<%= @quest.gold_reward %>G</span>
      <span class="text-muted" style="font-size:0.78rem;">初回クリア報酬</span>
    <% end %>
  </div>
</div>

<% if @quest.timed? %>
  <div class="timer-wrap" id="timer-wrap" style="display:none;">
    <div class="timer-label">⏱ 残り <span id="timer-seconds"><%= @quest.time_limit %></span> 秒</div>
    <div class="timer-bar-bg">
      <div class="timer-bar-fill" id="timer-bar"></div>
    </div>
  </div>
<% end %>

<% if flash[:hint].present? %>
  <div class="hint-box">💡 ヒント: <%= flash[:hint] %></div>
<% elsif current_user.active_item?("hint_book") && @quest.question_data["hint"].present? %>
  <%= form_with url: reveal_hint_quest_path(@quest), method: :post do |f| %>
    <%= f.submit "💡 ヒントを見る（ヒント本を1つ消費）", class: "btn btn-outline btn-sm" %>
  <% end %>
<% end %>

<div class="card" style="margin-top:0.75rem;">
  <%= form_with url: quest_attempts_path(@quest), method: :post, html: { id: "quest-form" } do |f| %>
    <% genre = @quest.daily_challenge.genre %>

    <% if genre == "memory" %>
      <p class="text-muted" style="font-size:0.88rem; margin-bottom:1rem;">数列を記憶してください</p>
      <div style="text-align:center; padding:1rem 0;">
        <button type="button" id="start-btn" class="btn btn-gold">準備できたら押してください</button>
        <p id="countdown" class="countdown-display" style="display:none;"></p>
        <p id="sequence-display" class="memory-display" style="display:none;"><%= @quest.question_data["sequence"].join("  ") %></p>
      </div>
      <div id="sequence-hidden" style="display:none;">
        <p class="text-muted" style="margin-bottom:0.5rem; font-size:0.9rem;">数列を入力してください（붙여서もOK）</p>
        <div class="form-group">
          <%= f.text_field :answer, placeholder: "例: 3141 または 3 1 4 1", id: "memory-answer", style: "display:none;" %>
        </div>
        <%= f.submit "回答する", id: "memory-submit", class: "btn btn-primary", style: "display:none;" %>
      </div>

    <% elsif genre == "word_puzzle" %>
      <div id="timed-ready" style="text-align:center; padding:0.5rem 0;">
        <button type="button" id="timed-start-btn" class="btn btn-gold">準備できたら押してください</button>
      </div>
      <div id="timed-content" style="display:none;">
        <div class="question-box"><%= @quest.question_data["question"] %></div>
        <ul class="choice-list">
          <% @quest.question_data["choices"].each do |choice| %>
            <li class="choice-item">
              <label>
                <%= f.radio_button :answer, choice %>
                <%= choice %>
              </label>
            </li>
          <% end %>
        </ul>
        <%= f.submit "回答する", class: "btn btn-primary" %>
      </div>

    <% else %>
      <div id="timed-ready" style="text-align:center; padding:0.5rem 0;">
        <button type="button" id="timed-start-btn" class="btn btn-gold">準備できたら押してください</button>
      </div>
      <div id="timed-content" style="display:none;">
        <div class="question-box"><%= @quest.question_data["question"] %></div>
        <div class="form-group">
          <%= f.number_field :answer, placeholder: "数字を入力", style: "font-size:1.2rem; text-align:center;" %>
        </div>
        <%= f.submit "回答する", class: "btn btn-primary" %>
      </div>
    <% end %>
  <% end %>
</div>

<%= link_to "← 依頼板に戻る", root_path, class: "text-muted" %>

<script>
  (function() {
    // 記憶カウントダウン
    var startBtn = document.getElementById('start-btn');
    if (startBtn) {
      startBtn.addEventListener('click', function() {
        startBtn.style.display = 'none';

        var countdown = document.getElementById('countdown');
        countdown.style.display = 'block';
        var count = 3;
        countdown.textContent = count;

        var timer = setInterval(function() {
          count -= 1;
          if (count > 0) {
            countdown.textContent = count;
          } else {
            clearInterval(timer);
            countdown.style.display = 'none';
            var display = document.getElementById('sequence-display');
            display.style.display = 'block';

            setTimeout(function() {
              display.style.display = 'none';
              document.getElementById('sequence-hidden').style.display = 'block';
              document.getElementById('memory-answer').style.display = 'block';
              document.getElementById('memory-submit').style.display = 'inline-block';
            }, 1000);
          }
        }, 1000);
      });
    }

    // 計算・言葉パズル：準備ボタン → タイマー開始
    var timedStartBtn = document.getElementById('timed-start-btn');
    var timerWrap     = document.getElementById('timer-wrap');
    var timerSeconds  = document.getElementById('timer-seconds');
    var timerBar      = document.getElementById('timer-bar');
    if (!timedStartBtn) return;

    timedStartBtn.addEventListener('click', function() {
      document.getElementById('timed-ready').style.display   = 'none';
      document.getElementById('timed-content').style.display = 'block';
      timerWrap.style.display = 'block';

      var total     = parseInt(timerSeconds.textContent, 10);
      var remaining = total;

      var countdown = setInterval(function() {
        remaining -= 1;
        timerSeconds.textContent = remaining;
        timerBar.style.width = (remaining / total * 100) + '%';

        if (remaining <= 5) {
          timerBar.classList.add('timer-bar-urgent');
        }

        if (remaining <= 0) {
          clearInterval(countdown);
          document.getElementById('quest-form').submit();
        }
      }, 1000);
    });
  })();
</script>
