<div class="page-header">
  <h1>冒険者ギルド 依頼板</h1>
  <p class="page-subtitle"><%= current_user.current_title %> — <%= current_user.email %></p>
</div>

<% if @daily_challenge.nil? %>
  <div class="card card-gold" style="text-align:center; padding:2.5rem;">
    <p style="font-size:1.5rem; margin-bottom:0.5rem;">📜</p>
    <p>本日の依頼はまだ届いていません。</p>
    <p class="text-muted mt-1" style="font-size:0.85rem;">管理者がデイリーチャレンジを生成するまでお待ちください。</p>
  </div>
<% else %>
  <div class="flex items-center gap-2 flex-wrap" style="margin-bottom:1rem;">
    <span class="genre-badge">
      <% case @daily_challenge.genre
         when "calculation" then %>🧮 計算
      <% when "memory"      then %>🧠 記憶
      <% when "word_puzzle" then %>📝 言葉パズル
      <% end %>
    </span>
    <span class="text-muted" style="font-size:0.85rem;">本日のジャンル</span>
  </div>

  <div class="quest-grid">
    <% @quests.each do |quest| %>
      <div class="quest-card <%= quest.difficulty %>">
        <div class="flex items-center justify-between">
          <% case quest.difficulty
             when "easy"   then %>
            <span class="badge badge-easy">易しい</span>
            <span class="stars">★</span>
          <% when "normal" then %>
            <span class="badge badge-normal">普通</span>
            <span class="stars">★★</span>
          <% when "hard"   then %>
            <span class="badge badge-hard">難しい</span>
            <span class="stars">★★★</span>
          <% end %>
        </div>
        <div class="quest-rewards">
          <span class="exp-val">EXP +<%= quest.exp_reward %></span>
          <span class="gold-val">💰 +<%= quest.gold_reward %>G</span>
        </div>
        <%= link_to "受注する →", quest_path(quest), class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
<% end %>
