<div class="guild-sign">冒険者ギルド 依頼板</div>

<div class="genre-picker">
  <% [["calculation", "🧮", "計算"], ["memory", "🧠", "記憶"], ["word_puzzle", "📝", "言葉パズル"]].each do |genre, icon, label| %>
    <%= link_to root_path(genre: genre),
          class: "genre-btn #{'genre-btn-active' if @selected_genre == genre}" do %>
      <span class="genre-btn-icon"><%= icon %></span>
      <span class="genre-btn-label"><%= label %></span>
    <% end %>
  <% end %>
</div>

<% if @selected_genre.nil? %>
  <div class="guild-board">
    <div class="board-empty">
      <p style="font-size:2rem; margin-bottom:0.5rem;">📜</p>
      <p>ジャンルを選んで依頼を受けよう</p>
    </div>
  </div>
<% else %>
  <div class="guild-board">
    <% cleared_ids = current_user.attempts.where(correct: true).pluck(:quest_id).to_set %>
    <% groups = @quests.group_by(&:difficulty) %>
    <% interleaved = (0...2).flat_map { |i| %w[easy normal hard].map { |d| groups[d]&.[](i) }.compact } %>

    <div class="quest-papers">
      <% interleaved.each do |quest| %>
        <% cleared = cleared_ids.include?(quest.id) %>
        <% rewarded = @rewarded_difficulties.include?(quest.difficulty) %>
        <div class="quest-paper <%= 'paper-cleared' if cleared %>">
          <p class="paper-heading <%= quest.difficulty %>-h">
            <% case quest.difficulty
               when "easy"   then %>— 易しい依頼 —
            <% when "normal" then %>— 普通の依頼 —
            <% when "hard"   then %>— 難しい依頼 —
            <% end %>
          </p>
          <p class="paper-swords">
            <% case quest.difficulty
               when "easy"   then %>⚔
            <% when "normal" then %>⚔⚔
            <% when "hard"   then %>⚔⚔⚔
            <% end %>
            <% if cleared %><span class="paper-cleared-stamp">✓ 完了</span><% end %>
          </p>
          <p class="paper-genre">
            <% case @daily_challenge.genre
               when "calculation" then %>計算問題
            <% when "memory"      then %>記憶問題
            <% when "word_puzzle" then %>言葉パズル
            <% end %>
          </p>
          <div class="paper-rewards">
            <% if rewarded %>
              <span style="color:#888; font-size:0.78rem;">本日の報酬受け取り済み</span>
            <% elsif cleared %>
              <span style="color:#888; font-size:0.78rem;">報酬受取済み</span>
            <% else %>
              <span class="p-exp">EXP +<%= quest.exp_reward %></span>
              <span class="p-gold">💰 +<%= quest.gold_reward %>G</span>
            <% end %>
          </div>
          <%= link_to cleared ? "もう一度挑戦" : "受注する", quest_path(quest), class: "paper-btn" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
