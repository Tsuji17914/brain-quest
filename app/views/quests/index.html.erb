<h1>冒険者ギルド - 本日の依頼板</h1>

<p>冒険者: <%= current_user.email %> | Lv.<%= current_user.level %> | EXP: <%= current_user.exp %> | Gold: <%= current_user.gold %>G</p>

<% if @daily_challenge.nil? %>
  <p>本日の依頼はまだ届いていません。</p>
<% else %>
  <p>本日のジャンル: <%= @daily_challenge.genre %></p>

  <div>
    <% @quests.each do |quest| %>
      <div>
        <h2>
          <% case quest.difficulty
             when "easy"   then %>★ 易しい
          <% when "normal" then %>★★ 普通
          <% when "hard"   then %>★★★ 難しい
          <% end %>
        </h2>
        <p>EXP: +<%= quest.exp_reward %> | Gold: +<%= quest.gold_reward %>G</p>
        <%= link_to "受注する", quest_path(quest), class: "btn" %>
      </div>
    <% end %>
  </div>
<% end %>
